<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="16dp">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="虚拟机列表" android:textSize="18sp" />

    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/recyclerVMs"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal">
        <EditText
            android:id="@+id/etVmHost"
            android:layout_width="0dp" android:layout_weight="1"
            android:layout_height="wrap_content" android:hint="虚拟机IP:端口" />
        <Button
            android:id="@+id/btnAddVm"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content" android:text="添加" />
    </LinearLayout>

    <Button
        android:id="@+id/btnManageApps"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="管理应用" />

    <Button
        android:id="@+id/btnStart"
        android:layout_width="match_parent"
        android:layout_height="wrap_content" android:text="开始自动任务" />
</LinearLayout>
